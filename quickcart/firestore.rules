rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isBootstrapAdmin(uid) {
      return isOwner(uid)
        && request.auth.token.email == 'admin@quickcart.com';
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && (
          request.resource.data.role == 'user'
          || (isBootstrapAdmin(uid) && request.resource.data.role == 'admin')
        );
      allow update: if isOwner(uid)
        && (
          request.resource.data.role == resource.data.role
          || (isBootstrapAdmin(uid) && request.resource.data.role == 'admin')
        );
      allow delete: if isAdmin();

      match /cart/{productId} {
        allow read, write: if isOwner(uid);
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(uid);
      }

      match /paymentMethods/{paymentMethodId} {
        allow read, write: if isOwner(uid);
      }

      match /favorites/{productId} {
        allow read, write: if isOwner(uid);
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isRead']);
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stock'])
          && request.resource.data.stock is int
          && resource.data.stock is int
          && request.resource.data.stock >= 0
        );
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if (
          isAdmin()
          || (
            signedIn()
            && resource.data.userId == request.auth.uid
            && request.resource.data.status == 'cancelled'
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'stockRestored']);
      allow delete: if isAdmin();
    }
  }
}
